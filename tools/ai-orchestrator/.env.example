# ============================================================
# AI Orchestrator Configuration
# ============================================================
# Copy this file to .env and customize values as needed.
# ============================================================

# ============================================================
# Layer 0: Required Settings
# ============================================================

# Tenant scopes for API requests (REQUIRED)
# Example: SCOPES=tenant:my-tenant
SCOPES=

# ============================================================
# Layer 1: Common Settings (Sensible Defaults)
# ============================================================

# RCA API base URL
# BASE_URL=http://127.0.0.1:5555

# Worker instance ID (auto-generated if not set)
# INSTANCE_ID=

# Maximum concurrent jobs per worker
# CONCURRENCY=1

# Enable debug logging
# DEBUG=0

# Health endpoint port
# HEALTH_PORT=8080

# ============================================================
# Layer 2: Conditional Settings (Mode-Dependent)
# ============================================================

# Skills execution mode: "prompt_first" or "catalog"
# - prompt_first: Uses LLM-driven skill execution (requires AGENT_* settings)
# - catalog: Uses platform-resolved skills (no LLM required)
SKILLS_EXECUTION_MODE=prompt_first

# LLM model name (Required when SKILLS_EXECUTION_MODE=prompt_first)
# AGENT_MODEL=gpt-4o

# OpenAI-compatible API base URL (Required when prompt_first)
# AGENT_BASE_URL=https://api.openai.com/v1

# API key for LLM provider (Required when prompt_first)
# AGENT_API_KEY=sk-xxx

# Request timeout in seconds
# AGENT_TIMEOUT_SECONDS=20.0

# ============================================================
# Layer 3: Advanced Settings (Optional)
# ============================================================

# Maximum tool calls per job
# A3_MAX_CALLS=6

# Maximum total response bytes (default 2MB)
# A3_MAX_TOTAL_BYTES=2097152

# Maximum total latency in milliseconds
# A3_MAX_TOTAL_LATENCY_MS=8000

# Execute real queries vs mock (0=mock, 1=real)
# RUN_QUERY=0

# Datasource type: prometheus, loki, or elasticsearch
# DS_TYPE=prometheus

# Enable post-finalize verification
# RUN_VERIFICATION=0

# Directory for skill bundle cache
# SKILLS_CACHE_DIR=/tmp/rca-ai-orchestrator/skills-cache

# MCP scopes for shim calls
# RCA_API_SCOPES=

# Maximum parallel workers for tool execution
# TOOL_EXECUTION_MAX_WORKERS=5