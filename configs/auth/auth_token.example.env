# JWT signing and validation
RCA_API_AUTH_JWT_SECRET=replace-with-strong-secret
RCA_API_AUTH_JWT_ISSUER=rca-api
RCA_API_AUTH_JWT_AUDIENCE=rca-api-operator

# Access/refresh token lifecycle
# Supports Go duration strings (e.g. 30m, 12h) or integer seconds.
RCA_API_AUTH_ACCESS_TOKEN_TTL=30m
RCA_API_AUTH_REFRESH_TOKEN_TTL=168h
RCA_API_AUTH_TOKEN_CLOCK_SKEW=5s

# Optional: OpenAPI-based dynamic RBAC action mapping path
RCA_API_AUTH_SWAGGER_PATH=api/openapi/apiserver/v1/rca-complete.swagger.json

# Optional: OIDC login (ID token verification)
RCA_API_AUTH_OIDC_ENABLED=false
RCA_API_AUTH_OIDC_ISSUER=https://issuer.example.com
RCA_API_AUTH_OIDC_AUDIENCE=rca-operator-ui

# Option A (HS256) - shared secret
RCA_API_AUTH_OIDC_HS256_SECRET=replace-with-oidc-hs256-secret

# Option B (RS256) - PEM public key or certificate
# RCA_API_AUTH_OIDC_RS256_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
